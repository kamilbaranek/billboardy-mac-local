<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.billboardy.occupancy-sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/kamilbaranek/dev/billboardy/run_sync.sh</string>
  </array>

  <key>StartOnMount</key>
  <true/>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/tmp/com.billboardy.occupancy-sync.stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/com.billboardy.occupancy-sync.stderr.log</string>
</dict>
</plist>
